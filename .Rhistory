install.packages("chromote")
library(chromote)
library(rvest)
library(dplyr)
library(stringr)
# Initialize browser session
b <- ChromoteSession$new()
url <- "https://www.maxpreps.com/lacrosse/scoreboard/boys/all/all-season/"
# Navigate to the URL
b$Page$navigate(url)
b$Page$loadEventFired()  # Wait until page loads
# Get the rendered HTML
html <- b$Runtime$evaluate("document.documentElement.outerHTML")$result$value
html
page <- read_html(html)
# Extract game data
games <- page %>%
html_elements(".ScoreboardListItem") %>%
map_df(function(game) {
teams <- game %>% html_elements(".TeamName") %>% html_text2()
scores <- game %>% html_elements(".Score") %>% html_text2()
date <- game %>% html_element(".DateStatus") %>% html_text2()
tibble(
Team1 = teams[1],
Team2 = teams[2],
Score1 = scores[1],
Score2 = scores[2],
Date = date
)
})
# Show results
print(games)
